# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# Enables GPT-4o analysis via POST /api/analyze.
# Without this key the offline rule engine is used automatically.
OPENAI_API_KEY=

# ── Clerk Auth (optional) ─────────────────────────────────────────────────────
# Get keys from https://dashboard.clerk.com → API Keys
# Until real keys are set, the app runs without auth (proxy pass-through).
# Real publishable keys look like pk_test_<50+ chars>.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Convex (Phase 2 — optional) ───────────────────────────────────────────────
# Leave unset until you run `npx convex dev` and wire schema/mutations.
# NEXT_PUBLIC_CONVEX_URL=
